class DatabaseConnection:
    _instance = None
    _initialized = False

    def __new__(cls, host=None, user=None, password=None):
        if cls._instance is None:
            cls._instance = super(DatabaseConnection, cls).__new__(cls)
        return cls._instance

    def __init__(self, host=None, user=None, password=None):
        if not self.__class__._initialized:
            if host is None or user is None or password is None:
                raise ValueError("Pierwsza inicjalizacja wymaga pełnej konfiguracji!")

            self.host = host
            self.user = user
            self.password = password

            # symulacja połączenia
            self.connection = self._connect()

            self.__class__._initialized = True
        else:
            # jeśli ktoś próbuje zmienić konfigurację
            if any([host, user, password]):
                raise RuntimeError("Konfiguracja została już ustawiona i nie może być zmieniona!")

    def _connect(self):
        print(f"Łączenie z bazą: {self.host} jako {self.user}")
        return "POŁĄCZENIE_OK"

    def query(self, sql):
        print(f"Wykonywanie zapytania: {sql}")
